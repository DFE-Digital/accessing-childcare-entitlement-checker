@using Microsoft.AspNetCore.Mvc.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Shared
@inject IViewLocalizer Localizer
@model ChildIsBornViewModel

@{
    ViewData["Title"] = Html.DisplayNameFor(model => model.ChildIsBorn);
}

@section BeforeContent {
    @if (Model.ReturnTo is not null)
    {
        <govuk-back-link asp-controller="Summary" asp-action="@(Model.ReturnTo == ReturnTo.CheckAnswers ? "CheckAnswers" : "CheckChildDetails")">
            @Shared["Button_Back"]
        </govuk-back-link>
    }
    else
    {
        <govuk-back-link asp-controller="Introduction" asp-action="ChildName" asp-route-childId="@Model.ChildId">
            @Shared["Button_Back"]
        </govuk-back-link>
    }
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form method="post" novalidate asp-route-childId="@Model.ChildId">
            <input type="hidden" asp-for="ReturnTo" />
            <govuk-radios for="ChildIsBorn">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @Html.DisplayNameFor(model => model.ChildIsBorn)
                    </govuk-radios-fieldset-legend>
                    <govuk-radios-error-message />
                    @foreach (var value in Enum.GetValues<BirthStatus>())
                    {
                        <govuk-radios-item value="@value">
                            @Html.EnumDisplayName(value)
                        </govuk-radios-item>
                    }
                </govuk-radios-fieldset>
            </govuk-radios>

            <govuk-button type="submit">
                @Shared["Button_Continue"]
            </govuk-button>
        </form>
    </div>
</div>
