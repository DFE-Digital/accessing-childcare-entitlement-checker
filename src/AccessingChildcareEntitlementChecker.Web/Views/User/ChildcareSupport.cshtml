@using AccessingChildcareEntitlementChecker.Web.Models.User
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Shared
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@model ChildcareSupportViewModel

@{
    ViewData["Title"] = Html.DisplayNameFor(model => model.ChildcareSupport);
}

@section BeforeContent {
    <govuk-back-link href="@Model.BackLink">
        @Shared["Button_Back"]
    </govuk-back-link>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form method="post" novalidate>
            <input type="hidden" asp-for="ReturnTo" />
            <cec-enum-checkboxes for="ChildcareSupport" exclusive-value="ChildcareSupportOption.None" />

            <govuk-details>
                <govuk-details-summary>
                    @Localizer["Why this childcare support matters"]
                </govuk-details-summary>
                <govuk-details-text>
                    <p class="govuk-body">
                        @Localizer["Some childcare support schemes cannot be used together. This information helps give you the most accurate results."]
                    </p>

                </govuk-details-text>
            </govuk-details>

            <govuk-button type="submit">
                @Shared["Button_Continue"]
            </govuk-button>
        </form>
    </div>
</div>
