@using Microsoft.AspNetCore.Mvc.Localization
@using AccessingChildcareEntitlementChecker.Web.Models.Cookies;
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Shared
@inject IViewLocalizer Localizer
@model CookiesViewModel

@{
    var title = Localizer["Cookies"];
    ViewData["Title"] = title;
}

@section BeforeContent {

}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        @if (Model.HasSetCookies)
        {
            <govuk-notification-banner type="NotificationBannerType.Success">
                <p class="govuk-notification-banner__heading">
                    @Localizer["You've set your cookie preferences."]
                    <a class="govuk-notification-banner__link" href="@Model.ReturnUrl">
                        @Localizer["Go back to the page you were looking at."]
                    </a>
                </p>
            </govuk-notification-banner>
        }

        <h1 class="govuk-heading-l">
            @title
        </h1>

        <p class="govuk-body">
            @Localizer["Cookies are small files saved on your phone, tablet or computer when you visit a website."]
        </p>

        <p class="govuk-body">
            @Localizer["We use cookies to make this site work and collect information about how you use our service."]
        </p>

        <h2 class="govuk-heading-m">
            @Localizer["Essential Cookies"]
        </h2>

        <p class="govuk-body">
            @Localizer["Essential cookies keep your information secure while you use this service. We do not need to ask permission to use them."]
        </p>

        <table class="govuk-table">
            <caption class="govuk-table__caption govuk-table__caption--s">
                @Localizer["Essential cookies we use"]
            </caption>
            <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header">@Localizer["Name"]</th>
                    <th scope="col" class="govuk-table__header">@Localizer["Purpose"]</th>
                    <th scope="col" class="govuk-table__header">@Localizer["Expires"]</th>
                </tr>
            </thead>
            <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell">@Localizer[".AspNetCore.Session"]</td>
                    <td class="govuk-table__cell">@Localizer["Maintains your progress through the checker."]</td>
                    <td class="govuk-table__cell">@Localizer["20 hours"]</td>
                </tr>
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell">@Localizer[".AspNetCore.Antiforgery.*"]</td>
                    <td class="govuk-table__cell">@Localizer["Protects against CSRF attacks."]</td>
                    <td class="govuk-table__cell">@Localizer["When you close your browser"]</td>
                </tr>
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell">@Localizer["cookie_policy"]</td>
                    <td class="govuk-table__cell">@Localizer["Saves your cookie consent settings"]</td>
                    <td class="govuk-table__cell">@Localizer["1 year"]</td>
                </tr>
            </tbody>
        </table>

        <table class="govuk-table">
            <caption class="govuk-table__caption govuk-table__caption--s">
                @Localizer["Optional cookies we use"]
            </caption>
            <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header">@Localizer["Name"]</th>
                    <th scope="col" class="govuk-table__header">@Localizer["Purpose"]</th>
                    <th scope="col" class="govuk-table__header">@Localizer["Expires"]</th>
                </tr>
            </thead>
            <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell">@Localizer["analytics TBC"]</td>
                    <td class="govuk-table__cell">@Localizer["TBC"]</td>
                    <td class="govuk-table__cell">@Localizer["TBC"]</td>
                </tr>
            </tbody>
        </table>

        <h2 class="govuk-heading-l">
            @Localizer["Change your cookie settings"]
        </h2>

        <form method="post" novalidate>
            <input type="hidden"
                   name="returnUrl"
                   value="@Model.ReturnUrl" />
            <govuk-radios for="IsAnalyticsEnabled">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend class="govuk-fieldset__legend--s">
                        @Localizer["Do you want to accept analytics cookies?"]
                    </govuk-radios-fieldset-legend>

                    <govuk-radios-error-message />

                    <govuk-radios-item value="True">
                        @Localizer[$"Yes"]
                    </govuk-radios-item>

                    <govuk-radios-item value="False">
                        @Localizer[$"No"]
                    </govuk-radios-item>

                </govuk-radios-fieldset>
            </govuk-radios>

            <govuk-button type="submit">
                @Shared["Button_Continue"]
            </govuk-button>
        </form>
    </div>
</div>