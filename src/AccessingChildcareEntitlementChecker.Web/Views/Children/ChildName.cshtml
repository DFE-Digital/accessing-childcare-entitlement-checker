@using Microsoft.AspNetCore.Mvc.Localization
@using AccessingChildcareEntitlementChecker.Web.Models.Children
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Shared
@inject IViewLocalizer Localizer
@model ChildNameViewModel

@section BeforeContent {
    <govuk-back-link asp-controller="Home" asp-action="Location">
        @Shared["Button_Back"]
    </govuk-back-link>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-l">
            @Localizer["Add details of a child"]
        </h1>

        <p class="govuk-body">
            @Localizer["You can add details for children you are expecting or already have."]
        </p>

        <p class="govuk-body">
            @Localizer["Enter details for one child at a time. If you have more than one child, you can add them later."]
        </p>

        <form method="post" asp-route-childId="@Model.ChildId" asp-antiforgery="true" novalidate>
            <govuk-input for="ChildName" label-class="govuk-label--m" input-class="govuk-input--width-20" />

            <govuk-details>
                <govuk-details-summary>
                    @Localizer["Why we ask for a name"]
                </govuk-details-summary>
                <govuk-details-text>
                    <p>
                        @Localizer["We use this name to make your results clearer and easier to understand."]
                    </p>
                    <p>
                        @Localizer["You do not need to use their real name. Any name you enter will not be stored or shared."]
                    </p>
                </govuk-details-text>
            </govuk-details>

            <govuk-button type="submit">
                @Shared["Button_Continue"]
            </govuk-button>
        </form>
    </div>
</div>
