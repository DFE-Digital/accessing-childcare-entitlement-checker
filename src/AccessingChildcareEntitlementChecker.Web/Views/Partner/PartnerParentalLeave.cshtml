@using AccessingChildcareEntitlementChecker.Web.Models.Partner
@using AccessingChildcareEntitlementChecker.Web.Services
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Shared
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@model PartnerParentalLeaveViewModel

@{
    ViewData["Title"] = Html.DisplayNameFor(model => model.PartnerParentalLeaveChildrenIds);
}

@section BeforeContent {
    <govuk-back-link href="@Model.BackLink">
        @Shared["Button_Back"]
    </govuk-back-link>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <partial name="~/Views/Shared/_ErrorSummary.cshtml" />

        <h1 class="govuk-heading-l">
            @Html.DisplayNameFor(model => model.PartnerParentalLeaveChildrenIds)
        </h1>
        <form method="post" novalidate>
            <input type="hidden" asp-for="ReturnTo" />

            <partial name="~/Views/Shared/_ChildrenCheckboxes.cshtml" model="@((
                nameof(Model.PartnerParentalLeaveChildrenIds),
                Html.DisplayNameFor(m => m.PartnerParentalLeaveChildrenIds),
                (IReadOnlyList<Child>)Model.Children,
                (IReadOnlyList<string>)Model.PartnerParentalLeaveChildrenIds))" />

            <govuk-error-summary/>

            <govuk-button type="submit">
                @Shared["Button_Continue"]
            </govuk-button>
        </form>
    </div>
</div>
