@using System.Text.Json
@using AccessingChildcareEntitlementChecker.Web.Controllers
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Mvc.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Shared
@inject IViewLocalizer Localizer
@inject IAntiforgery Antiforgery

@{
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken
        ?? throw new InvalidOperationException("Could not generate antiforgery token.");
    var consentUrl = Url.Action(
        nameof(CookiesController.BannerConsent),
        CookiesController.Name);
    var heading = Localizer["Cookies on Check if you are eligible for childcare funding"];
}

<govuk-cookie-banner aria-label="@heading.Value" id="cookies-banner" hidden="true">
    <govuk-cookie-banner-message id="unselected-cookies-banner">
        <govuk-cookie-banner-message-heading>@heading</govuk-cookie-banner-message-heading>
        <govuk-cookie-banner-message-content>
            <p class="govuk-body">
                @Localizer["We use some essential cookies to make this service work."]
            </p>

            <p class="govuk-body">
                @Localizer["We’d also like to use analytics cookies so we can understand how you use the service and make improvements."]
            </p>
        </govuk-cookie-banner-message-content>
        <govuk-cookie-banner-message-actions>
            <govuk-cookie-banner-message-action name="analyticsEnabled"
                                                id="accept-cookies"
                                                text="@Localizer["Accept analytics cookies"].Value"
                                                type="submit"
                                                value="True" />
            <govuk-cookie-banner-message-action name="analyticsEnabled"
                                                id="reject-cookies"
                                                text="@Localizer["Reject analytics cookies"].Value"
                                                type="submit"
                                                value="False" />
            <govuk-cookie-banner-message-action-link text="@Localizer["View cookies"].Value"
                                                     asp-action="@nameof(CookiesController.Cookies)"
                                                     asp-controller="@CookiesController.Name" />
        </govuk-cookie-banner-message-actions>
    </govuk-cookie-banner-message>

    <govuk-cookie-banner-message role="alert" id="accepted-cookies-banner" hidden="true">
        <govuk-cookie-banner-message-content>
            <p class="govuk-body">
                @Localizer["You've accepted analytics cookies. You can"]
                <a class="govuk-link" href="@Url.Action(nameof(CookiesController.Cookies), CookiesController.Name)">
                    @Localizer["change your cookie settings"]
                </a>
                @Localizer["at any time."]
            </p>
        </govuk-cookie-banner-message-content>
        <govuk-cookie-banner-message-actions>
            <govuk-cookie-banner-message-action class="hide-cookies" text="@Localizer["Hide cookie message"].Value" />
        </govuk-cookie-banner-message-actions>
    </govuk-cookie-banner-message>

    <govuk-cookie-banner-message role="alert" id="rejected-cookies-banner" hidden="true">
        <govuk-cookie-banner-message-content>
            <p class="govuk-body">
                @Localizer["You've rejected analytics cookies. You can"]
                <a class="govuk-link" href="@Url.Action(nameof(CookiesController.Cookies), CookiesController.Name)">
                    @Localizer["change your cookie settings"]
                </a>
                @Localizer["at any time."]
            </p>
        </govuk-cookie-banner-message-content>
        <govuk-cookie-banner-message-actions>
            <govuk-cookie-banner-message-action class="hide-cookies" text="@Localizer["Hide cookie message"].Value" />
        </govuk-cookie-banner-message-actions>
    </govuk-cookie-banner-message>
</govuk-cookie-banner>

<script type="text/javascript" add-nonce="true">
    const antiforgeryToken = @Html.Raw(JsonSerializer.Serialize(antiforgeryToken));
    const consentUrl = @Html.Raw(JsonSerializer.Serialize(consentUrl));

    async function saveCookiePreference(enabled) {
        const body = new URLSearchParams({
            AnalyticsCookiesEnabled: enabled.toString(),
            __RequestVerificationToken: antiforgeryToken
        });

        const response = await fetch(consentUrl, {
            method: "POST",
            credentials: "same-origin",
            headers: {
                "Content-Type": "application/x-www-form-urlencoded"
            },
            body
        });

        if (!response.ok) {
            throw new Error(
                `Saving cookie preference failed with status ${response.status}.`);
        }
    }

    async function acceptOrRejectClick(enabled) {
        await saveCookiePreference(enabled);

        document
            .getElementById("unselected-cookies-banner")
            .setAttribute("hidden", "hidden");

        document
            .getElementById(enabled ? "accepted-cookies-banner" : "rejected-cookies-banner")
            .removeAttribute("hidden");
    }

    var cookiesBanner = document.getElementById("cookies-banner");
    if (cookiesBanner !== null) {
        cookiesBanner.removeAttribute("hidden");

        var acceptButton = document.getElementById("accept-cookies");
        acceptButton.addEventListener("click", (e) => { e.preventDefault(); acceptOrRejectClick(true); });

        var rejectButton = document.getElementById("reject-cookies");
        rejectButton.addEventListener("click", (e) => { e.preventDefault(); acceptOrRejectClick(false); });

        var hideCookiesButtons = document.getElementsByClassName("hide-cookies");
        for (var i = 0; i < hideCookiesButtons.length; i++) {
            hideCookiesButtons[i].addEventListener("click", () => cookiesBanner.setAttribute("hidden", "hidden"));
        }
    }
</script>