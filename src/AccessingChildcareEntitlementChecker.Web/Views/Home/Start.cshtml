@model AccessingChildcareEntitlementChecker.Web.Models.WhereDoYouLiveViewModel
@using AccessingChildcareEntitlementChecker.Web.Controllers
@using Microsoft.AspNetCore.Mvc.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Shared
@inject IViewLocalizer Localizer


<form method="post" novalidate>
    
    <h1 class="govuk-heading-xl">
        @Localizer["Title"]
    </h1>
    
    <p class="govuk-body">
        @Localizer["Intro"]
    </p>
    
    <ul class="govuk-list govuk-list--bullet">
        <li>@Localizer["Scheme1"]</li>
        <li>@Localizer["Scheme2"]</li>
        <li>@Localizer["Scheme3"]</li>
        <li>@Localizer["Scheme4"]</li>
        <li>@Localizer["Scheme5"]</li>
    </ul>
    
    <h2 class="govuk-heading-l">
        @Localizer["WhatYouNeedHeading"]
    </h2>
    
    <p class="govuk-body">
        @Localizer["WhatYouNeedIntro"]
    </p>
    
    <ul class="govuk-list govuk-list--bullet">
        <li>@Localizer["Parent_Need1"]</li>
        <li>@Localizer["Parent_Need2"]</li>
        <li>@Localizer["Parent_Need3"]</li>
        <li>@Localizer["Parent_Need4"]</li>
    </ul>
    
    <p class="govuk-body">
        @Localizer["WhatYouNeedChildIntro"]
    </p>
    
    <ul class="govuk-list govuk-list--bullet">
        <li>@Localizer["Child_Need1"]</li>
        <li>@Localizer["Child_Need2"]</li>
    </ul>
    
    <p class="govuk-body">
        @Localizer["Time"]
    </p>
    
    <!-- NOSONAR -->
    <a asp-action="@nameof(HomeController.WhereDoYouLive)"
       class="govuk-button govuk-button--start"
       data-module="govuk-button">
        
        @Localizer["Button_Start"]
        
        <svg class="govuk-button__start-icon" 
             xmlns="http://www.w3.org/2000/svg" 
             width="17.5" 
             height="19" 
             viewBox="0 0 33 40" 
             aria-hidden="true" 
             focusable="false">
            <path fill="currentColor" 
                  d="M0 0h13l20 20-20 20H0l20-20z"/>
        </svg>
    </a>
</form>