@using AccessingChildcareEntitlementChecker.Web.Models.BornChildDetails
@using AccessingChildcareEntitlementChecker.Web.Services
@using Microsoft.AspNetCore.Mvc.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Shared
@inject IViewLocalizer Localizer
@model ChildBirthDateViewModel
@inject AccessingChildcareEntitlementChecker.Web.Services.JourneyState JourneyState

@section BeforeContent {
    @if (Model.ReturnTo == "check-your-childrens-details")
    {
        <govuk-back-link asp-controller="CheckChildDetails" asp-action="CheckChildDetails">
            @Shared["Button_Back"]
        </govuk-back-link>
    }
    else
    {
        <govuk-back-link asp-controller="Introduction" asp-action="IsChildBorn" asp-route-childId="@Model.ChildId">
            @Shared["Button_Back"]
        </govuk-back-link>
    }
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <form method="post" asp-route-childId="@Model.ChildId" asp-antiforgery="true" novalidate>
            <input type="hidden" asp-for="ReturnTo" />

            <govuk-date-input for="ChildBirthDate">
                <govuk-date-input-fieldset>
                    <govuk-date-input-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @Localizer["What is {0}'s date of birth?", Model.ChildName!]
                    </govuk-date-input-fieldset-legend>

                    <govuk-date-input-hint>
                        @Localizer["For example, 31 3 2022"]
                    </govuk-date-input-hint>

                    <govuk-date-input-error-message />
                </govuk-date-input-fieldset>
            </govuk-date-input>

            <details class="govuk-details">
                <summary class="govuk-details__summary">
                    <span class="govuk-details__summary-text">@Localizer["Why this date matters"]</span>
                </summary>
                <div class="govuk-details__text">
                    <p class="govuk-body">
                        @Localizer["The date of birth is used to give you accurate results, including when you may be able to apply and when childcare support could start and end."]
                    </p>
                </div>
            </details>

            <govuk-button type="submit">
                @Shared["Button_Continue"]
            </govuk-button>
        </form>
    </div>
</div>
