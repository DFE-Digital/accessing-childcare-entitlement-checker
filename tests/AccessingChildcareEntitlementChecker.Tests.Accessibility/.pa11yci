{
  "defaults": {
    "standard": "WCAG2AA",
    "runners": ["axe", "htmlcs"],
    "timeout": 10000,
    "chromeLaunchConfig": {
      "args": [
        "--no-sandbox",
        "--disable-dev-shm-usage"
      ]
    }
  },
  "urls": [
    "http://localhost:5252/",
    "http://localhost:5252/Home/WhereDoYouLive",
    "http://localhost:5252/Home/SessionExpired"
  ]
}
